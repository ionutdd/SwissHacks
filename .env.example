# Copy this file to .env for local Apertus AI enrichment.
# .env is intentionally ignored by Git and must never be committed.
#
# APERTUS_BASE_URL may be either:
# - an OpenAI-compatible /v1 base URL, or
# - a full /chat/completions endpoint.
#
# Keep values empty in this tracked template.
APERTUS_API_KEY=
APERTUS_BASE_URL=
APERTUS_MODEL=
